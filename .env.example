GRIDBOT_COINBASE_API_KEY=your_api_key_here
GRIDBOT_COINBASE_API_SECRET=your_api_secret_here
GRIDBOT_CONFIG_PATH=config/default.yaml
GRIDBOT_DB_PATH=data/grid_bot.db

# ── X (Twitter) Reply Bot ───────────────────────────────────────────────────
# Required for reading tweets and replies (free tier works):
X_BEARER_TOKEN=your_x_bearer_token_here

# Required only if you want the bot to auto-post replies (--post-best flag):
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here

# Anthropic Claude API key (required for AI reply generation):
ANTHROPIC_API_KEY=your_anthropic_api_key_here
